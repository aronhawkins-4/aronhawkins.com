---

---

<section class='hero'>
	<div class='wrap hero-grid'>
		<div>
			<h1
				class='reveal'
				data-delay='1'
			>
				Custom web and mobile apps, built for your business.
			</h1>
			<p
				class='lede reveal'
				data-delay='2'
			>
				I'm Aron Hawkins, a full-stack developer in Texas. I build custom software for businesses, startups, and agencies, turning their ideas into real products. I specialize in building
				tools that make work easier, faster, and more enjoyable.
			</p>
			<div
				class='hero-cta reveal'
				data-delay='3'
			>
				<a
					href='https://cal.com/aron-hawkins/15min'
					class='btn btn-primary'
					>Book a 15-minute call <span class='btn-arrow'>→</span></a
				>
				<a
					href='#work'
					class='btn btn-ghost'
					>See my work</a
				>
			</div>
			<p
				class='hero-note reveal'
				data-delay='4'
			>
				Available for new projects.
			</p>
		</div>
		<img
			src='/images/HAWKINS-248.avif'
			alt='Portrait of Aron Hawkins'
			class='hero-portrait portrait reveal'
			data-delay='2'
		/>
	</div>
</section>
